POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_CHAR_STRING
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# AI Service (recommender-ai-service)
# ─────────────────────────────────────────────

# LLM Provider: mock | openrouter | anthropic | openai
#   - mock: Không gọi API, dùng rule-based (cho dev/test)
#   - openrouter: Default cho MVP, dùng free model
#   - anthropic: Claude API (cần API key trả phí)
#   - openai: GPT API (cần API key trả phí)
LLM_PROVIDER=openrouter

# OpenRouter Configuration (default provider)
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:8888
OPENROUTER_APP_NAME=Store AI

# Anthropic (khi LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI (khi LLM_PROVIDER=openai)
OPENAI_API_KEY=